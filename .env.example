# Hub gate: copy to `.env.local` (gitignored) and set your password.
# Use DOUBLE quotes if the value contains # or $.
# Example: VITE_HUB_PASSWORD="P@$$w0rd!@#$%^"
# Or base64 (avoids all special-char issues): VITE_HUB_PASSWORD_B64=UEBAJCR3MHIwcmQhQCMkJQ==
VITE_HUB_PASSWORD=

# AI roadmap dashboard — live sync (optional; without these, dashboard uses localStorage only)
# Supabase → Project Settings → API → Project URL and anon public key
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
